        .service-card-full {
            grid-column: 1 / -1;
        }

        /* ============================================
           PROCESS SECTION
        ============================================ */
        .process-section {
            background: var(--light-bg);
        }

        .process-timeline {
            max-width: 900px;
            margin: 0 auto;
            position: relative;
        }

        .process-timeline::before {
            content: '';
            position: absolute;
            top: 0;
            left: 50px;
            width: 2px;
            height: 100%;
            background: linear-gradient(to bottom, var(--secondary-gold), var(--accent-purple));
        }

        .process-step {
            display: flex;
            gap: 40px;
            margin-bottom: 50px;
            align-items: flex-start;
            position: relative;
        }

        .process-step:last-child {
            margin-bottom: 0;
        }

        .process-number {
            width: 100px;
            min-width: 100px;
            height: 100px;
            border-radius: 50%;
