            font-size: 1rem;
            color: var(--secondary-gold);
            font-style: italic;
            margin-bottom: 18px;
        }

        .service-card p {
            font-size: 0.9rem;
            color: rgba(240, 236, 228, 0.6);
            line-height: 1.8;
            margin-bottom: 20px;
        }

        .service-features {
            list-style: none;
            margin-top: 15px;
        }

        .service-features li {
            font-size: 0.85rem;
            color: rgba(240, 236, 228, 0.7);
            padding: 6px 0;
            padding-left: 20px;
            position: relative;
        }

        .service-features li::before {
            content: '✦';
            position: absolute;
            left: 0;
            color: var(--secondary-gold);
            font-size: 0.6rem;
        }

        .service-card .service-ideal {
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid rgba(200, 169, 81, 0.1);
        }

        .service-card .service-ideal h5 {
            font-size: 0.75rem;
            color: var(--secondary-gold);
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 10px;
        }

        .service-card .service-ideal p {
            font-size: 0.85rem;
            margin-bottom: 0;
        }

