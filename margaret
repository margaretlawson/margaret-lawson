           WHY CHOOSE SECTION
        ============================================ */
        .why-section {
            background: var(--dark-bg);
        }

        .why-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 25px;
        }

        .why-card {
            display: flex;
            gap: 20px;
            padding: 30px;
            background: var(--charcoal);
            border-radius: 12px;
            border: 1px solid rgba(200, 169, 81, 0.08);
            transition: all 0.3s ease;
        }

        .why-card:hover {
            border-color: rgba(200, 169, 81, 0.2);
            transform: translateX(5px);
        }

        .why-card .why-icon {
            font-size: 1.5rem;
            min-width: 40px;
        }

        .why-card h4 {
            font-family: 'Montserrat', sans-serif;
            font-size: 0.95rem;
            font-weight: 700;
            color: var(--secondary-gold);
            margin-bottom: 8px;
        }

        .why-card p {
            font-size: 0.9rem;
            color: rgba(240, 236, 228, 0.6);
            line-height: 1.7;
        }

        /* ============================================
           FAQ SECTION
        ============================================ */
        .faq-section {
            background: var(--light-bg);
        }

        .faq-container {
            max-width: 850px;
            margin: 0 auto;
        }

        .faq-item {
            background: white;
            border-radius: 12px;
            margin-bottom: 15px;
