            color: var(--secondary-gold);
        }

        /* ============================================
           SERVICES SECTION
        ============================================ */
        .services-section {
            background: var(--dark-bg);
        }

        .services-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 30px;
        }

        .service-card {
            background: var(--charcoal);
            border-radius: 15px;
            padding: 45px;
            border: 1px solid rgba(200, 169, 81, 0.1);
