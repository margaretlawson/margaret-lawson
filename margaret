        .blog-card-content p {
            font-size: 0.85rem;
            color: var(--text-dark);
            opacity: 0.7;
            line-height: 1.7;
            margin-bottom: 15px;
        }

        .blog-card-content .read-more {
            font-family: 'Montserrat', sans-serif;
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--secondary-gold);
            letter-spacing: 2px;
            text-transform: uppercase;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

        .blog-card-content .read-more:hover {
            gap: 10px;
        }

        .blog-view-all {
            text-align: center;
        }

