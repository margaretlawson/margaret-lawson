            opacity: 0.3;
            line-height: 1;
            margin-bottom: 10px;
        }

        .testimonial-card .stars {
            color: var(--secondary-gold);
            font-size: 0.9rem;
            margin-bottom: 15px;
            letter-spacing: 3px;
        }

        .testimonial-card p {
            font-size: 0.95rem;
            color: var(--text-dark);
            opacity: 0.8;
            line-height: 1.8;
            margin-bottom: 20px;
            font-style: italic;
        }

        .testimonial-author {
            display: flex;
            align-items: center;
            gap: 15px;
            padding-top: 20px;
            border-top: 1px solid rgba(0, 0, 0, 0.05);
        }

        .testimonial-author-avatar {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: var(--gradient-1);
            display: flex;
            justify-content: center;
            align-items: center;
            color: var(--secondary-gold);
            font-family: 'Playfair Display', serif;
            font-size: 1.2rem;
            font-weight: 700;
        }

        .testimonial-author-info h5 {
            font-size: 0.9rem;
            font-weight: 700;
            color: var(--primary-navy);
        }

        .testimonial-author-info span {
            font-size: 0.75rem;
            color: var(--text-muted);
            font-style: italic;
        }

