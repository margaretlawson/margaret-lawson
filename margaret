            color: rgba(200, 169, 81, 0.3);
        }

        .blog-card-content {
            padding: 30px;
        }

        .blog-card-content .blog-category {
            font-family: 'Montserrat', sans-serif;
            font-size: 0.65rem;
            font-weight: 600;
            color: var(--secondary-gold);
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 10px;
            display: inline-block;
        }

        .blog-card-content h3 {
            font-size: 1.1rem;
            color: var(--primary-navy);
            margin-bottom: 12px;
            font-weight: 700;
            line-height: 1.4;
