            opacity: 1;
        }

        .service-card .service-number {
            font-family: 'Playfair Display', serif;
            font-size: 3rem;
            font-weight: 800;
            color: rgba(200, 169, 81, 0.1);
            position: absolute;
            top: 20px;
            right: 25px;
        }

        .service-card .service-icon {
            font-size: 2rem;
            margin-bottom: 20px;
            display: inline-block;
        }

        .service-card h3 {
            font-size: 1.3rem;
            color: var(--text-light);
            margin-bottom: 8px;
            font-weight: 700;
        }

        .service-card .service-tagline {
